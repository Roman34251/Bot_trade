# Copy to .env on the server. Never commit the real .env.

# Mode and credentials. Live requires both BYBIT_DEMO=false and
# CONFIRM_LIVE_TRADING=LIVE when telegrambot.py --live is used.
BYBIT_DEMO=true
BYBIT_DEMO_KEY=replace_me
BYBIT_DEMO_SECRET=replace_me
BYBIT_API_KEY=
BYBIT_API_SECRET=
CONFIRM_LIVE_TRADING=

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ADMIN_ID=replace_me

DB_HOST=localhost
DB_PORT=5432
DB_NAME=quant_bot
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_CONNECT_TIMEOUT=5
ENABLE_TRADE_DB_LOG=true

# Risk and execution
USE_REAL_BALANCE=true
DEPOSIT_USDT=5000
RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_PCT=0.03
MIN_RISK_REWARD=1.25
BYBIT_LEVERAGE=0
MAX_NOTIONAL_EQUITY_MULT=0
BYBIT_TAKER_FEE=0.00055
BYBIT_MAKER_FEE=0.00020
BTC_SLIPPAGE_PCT=0.00015
MAX_ENTRY_DRIFT_BPS=12

MIN_CANDLES_BETWEEN_TRADES=2
MAX_TRADES_PER_DAY=30
COOLDOWN_AFTER_LOSS_MIN=8
MAX_CONSECUTIVE_LOSSES=4
COOLDOWN_AFTER_SERIES_MIN=45
TRADE_HOURS_ONLY=true
TRADE_HOUR_START=7
TRADE_HOUR_END=21

SIGNALS_USE_CLOSED_CANDLES=true
SIGNAL_DEDUP_ENABLED=true
USE_MAKER_ENTRY=false
MAKER_ENTRY_TTL_SEC=4
MAKER_FALLBACK_TO_MARKET=true

# Strategies
USE_TREND_STRATEGY=true
USE_VWAP_STRATEGY=true
USE_MEANREV_STRATEGY=true
USE_SWEEP_STRATEGY=true
USE_DUAL_TF_STRATEGY=false
STRATEGY_PRIORITY=trend,vwap,meanrev,sweep

TREND_ENABLED=true
TREND_ENTRY_TF=5m
TREND_ADX_MIN=22
TREND_TP_R=2.2
TREND_MIN_RR=1.4
TREND_USE_RSI=false
TREND_REQUIRE_INTACT_PULLBACK=true
TREND_REQUIRE_ADX_RISING=true
TREND_ADX_RISE_LOOKBACK=2
TREND_ADX_RISE_MIN=0

VWAP_ENABLED=true
VWAP_MODE=session
VWAP_WINDOW=96
VWAP_K_BAND=2.0
VWAP_MIN_DEV_PCT=0.20
VWAP_MIN_RR=0.7
VWAP_USE_ADX=true
VWAP_ADX_MAX=28
VWAP_REQUIRE_REVERSAL=true
VWAP_USE_TREND_FILTER=true

MEANREV_ENABLED=true
MEANREV_RSI_OS=32
MEANREV_RSI_OB=68
MEANREV_MIN_WIDTH_PCT=0.25
MEANREV_MIN_RR=0.7
MEANREV_USE_ADX=true
MEANREV_ADX_MAX=35
MEANREV_REQUIRE_RSI_HOOK=true
MEANREV_RSI_HOOK_DELTA=0.5
MEANREV_REQUIRE_RECLAIM=true
MEANREV_USE_TREND_FILTER=true

SWEEP_MIN_RR=1.6
SWEEP_MIN_CONFIRMATIONS=2
SWEEP_USE_OB_CONFIRM=true

# Depth and executed flow
USE_ORDER_BOOK_CONFIRMATION=false
USE_ORDER_BOOK_WALL_FILTER=true
OB_IMBALANCE_LONG_MIN=20
OB_IMBALANCE_SHORT_MAX=-20
OB_MAX_AGE_SECONDS=10
OB_WALL_THRESHOLD_MULT=8.0
OB_WALL_BLOCK_PCT=0.0005
OB_PERSISTENCE_WINDOW_SEC=3
OB_PERSISTENCE_MIN_SEC=1
OB_PERSISTENCE_MIN_SAMPLES=5
OB_PERSISTENCE_MIN_RATIO=0.70
SWEEP_REQUIRE_TRADE_FLOW=true
TRADE_FLOW_LOOKBACK_SEC=3
TRADE_FLOW_IMBALANCE_MIN=20
TRADE_FLOW_MIN_NOTIONAL=50000

USE_FTA_FILTER=false
FTA_TF=1h
FTA_SWING_LOOKBACK=3
FTA_BUFFER_PCT=0.0005

LOG_LEVEL=DEBUG
LOG_RETENTION=30 days
