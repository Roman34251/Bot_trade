# ── Order Book: пороги під BTC (топ-25 рівнів стакана) ──────────
OB_IMBALANCE_LONG_MIN=20      # було 12: на BTC ±12% — це шум, ±20% = реальний перекіс покупців
OB_IMBALANCE_SHORT_MAX=-20    # дзеркально для шортів
OB_MAX_AGE_SECONDS=10         # було 30: live-потік тепер пушить щосекунди; старіше 10с = не довіряти
OB_WALL_THRESHOLD_MULT=8.0    # було 3.0: на BTC рівень 3× середнього трапляється ПОСТІЙНО (тому фільтр різав усе); 8× = справжня стіна
OB_WALL_BLOCK_PCT=0.0005      # було 0.003: 0.3% від 63k = $190 зона — стіни там є завжди; 0.05% (~$30) = стіна впритул до входу

# ── Перемикачі — у тебе правильно, лишай так ─────────────────────
