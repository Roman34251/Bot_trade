# ─── BYBIT (заповниш коли будемо підключати live/demo) ─
# Поки порожньо — для збору публічних даних не потрібно
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_DEMO=true


# ─── НАЛАШТУВАННЯ БОТА ────────────────────────────────
PRIMARY_EXCHANGE=bybit
#----API KEY--------------------
BYBIT_DEMO_KEY=omXkRhiVG0mLSiLYrJ
BYBIT_DEMO_SECRET=buiOugN3VWGooN166cM0XkEektOklj0eCebi
#----API KEY--------------------
TELEGRAM_BOT_TOKEN=8362281330:AAGClqlLk8YdlA79UKxMO40JAJvpwTaLwi4
TELEGRAM_ADMIN_ID=909089071

#BYBIT_PROXY=http://djowvspi:95bcn5h1xozj@64.137.96.74:6641

MIN_SL_PCT=0.0022
TRADE_HOURS_ONLY=true
TRADE_HOUR_START=7
TRADE_HOUR_END=21
# ── Перемикачі — у тебе правильно, лишай так ─────────────────────

# ── Капітал / ризик ──────────────────────────────────────────────
USE_REAL_BALANCE=true        # true = капітал з акаунта через API
DEPOSIT_USDT=5000             # fallback якщо API недоступний
RISK_PER_TRADE_PCT=0.01       # рівно 1% equity — цільовий NET-ризик до SL
MAX_DAILY_LOSS_PCT=0.03      # стоп-день при -3%
MIN_RISK_REWARD=1.25         # fallback NET-RR (стратегії мають власні)
BYBIT_LEVERAGE=0              # 0 = не змінювати плече, задане на Bybit
MAX_NOTIONAL_EQUITY_MULT=0    # 0 = без штучного cap; обсяг рахується від ризику 1%
BYBIT_TAKER_FEE=0.00055
BYBIT_MAKER_FEE=0.00020
BTC_SLIPPAGE_PCT=0.00015
# Для live-запуску telegrambot.py потрібне явне CONFIRM_LIVE_TRADING=LIVE.
CONFIRM_LIVE_TRADING=

# ── Ліміти / кулдауни ────────────────────────────────────────────
MIN_CANDLES_BETWEEN_TRADES=2 # хвилин між угодами
MAX_TRADES_PER_DAY=30
COOLDOWN_AFTER_LOSS_MIN=8    # пауза після збитку
MAX_CONSECUTIVE_LOSSES=4     # стоп після серії збитків...
COOLDOWN_AFTER_SERIES_MIN=45 # ...і автоскидання серії після цієї паузи
SIGNALS_USE_CLOSED_CANDLES=true
SIGNAL_DEDUP_ENABLED=true
MAX_ENTRY_DRIFT_BPS=12
USE_MAKER_ENTRY=false
MAKER_ENTRY_TTL_SEC=4
MAKER_FALLBACK_TO_MARKET=true

# ── Перемикачі стратегій ─────────────────────────────────────────
USE_TREND_STRATEGY=true
USE_VWAP_STRATEGY=true
USE_MEANREV_STRATEGY=true
USE_SWEEP_STRATEGY=true
USE_DUAL_TF_STRATEGY=false   # легасі, не чіпати
STRATEGY_PRIORITY=trend,vwap,meanrev,sweep

# ── РУЧКИ ТЮНІНГУ (жорсткішаємо після кожних ~5 угод) ────────────
# TREND (EMA-stack pullback, 1h→5m)
TREND_ENABLED=true
TREND_ENTRY_TF=5m            # 15m = менше але чистіше
TREND_ADX_MIN=22
TREND_TP_R=2.2               # ціль у R (gross)
TREND_MIN_RR=1.4             # NET-поріг; ↑ жорсткіше
TREND_USE_RSI=false          # true = додатковий RSI-фільтр
TREND_REQUIRE_INTACT_PULLBACK=true
TREND_REQUIRE_ADX_RISING=true
TREND_ADX_RISE_LOOKBACK=2
TREND_ADX_RISE_MIN=0

# VWAP (σ-band reversion, 5m)
VWAP_ENABLED=true
VWAP_MODE=session
VWAP_WINDOW=96
VWAP_K_BAND=2.0              # ↑ жорсткіше: 2.0 → 2.2
VWAP_MIN_DEV_PCT=0.20
VWAP_MIN_RR=0.7              # NET-RR; жорсткіше = більше
VWAP_USE_ADX=true
VWAP_ADX_MAX=28

# MEANREV (BB+RSI, 5m)
MEANREV_ENABLED=true
MEANREV_RSI_OS=32            # ↓ жорсткіше: 32 → 30
MEANREV_RSI_OB=68            # ↑ жорсткіше: 68 → 70
MEANREV_MIN_WIDTH_PCT=0.25   # ↑ жорсткіше: 0.25 → 0.30
MEANREV_MIN_RR=0.7           # NET-RR; жорсткіше = більше
MEANREV_USE_ADX=true
MEANREV_ADX_MAX=35
MEANREV_REQUIRE_RSI_HOOK=true
MEANREV_RSI_HOOK_DELTA=0.5

# SWEEP
SWEEP_MIN_RR=1.6
SWEEP_MIN_CONFIRMATIONS=2
SWEEP_USE_OB_CONFIRM=true

# ── Order Book (фільтри вимкнені; пороги відкалібровані під BTC) ──
USE_ORDER_BOOK_CONFIRMATION=false
USE_ORDER_BOOK_WALL_FILTER=true
OB_IMBALANCE_LONG_MIN=20
OB_IMBALANCE_SHORT_MAX=-20
OB_MAX_AGE_SECONDS=10
OB_WALL_THRESHOLD_MULT=8.0
OB_WALL_BLOCK_PCT=0.0005
OB_PERSISTENCE_WINDOW_SEC=3
OB_PERSISTENCE_MIN_SEC=1
OB_PERSISTENCE_MIN_SAMPLES=5
OB_PERSISTENCE_MIN_RATIO=0.70
SWEEP_REQUIRE_TRADE_FLOW=true
TRADE_FLOW_LOOKBACK_SEC=3
TRADE_FLOW_IMBALANCE_MIN=20
TRADE_FLOW_MIN_NOTIONAL=50000

# ── Логи ─────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_RETENTION=30 days
ENABLE_TRADE_DB_LOG=true

USE_FTA_FILTER=false
FTA_TF=1h
